# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Python backend listens on this port when using npm run dev.
APP_HOST="127.0.0.1"
APP_PORT="4000"

# Vite frontend listens on this port when using npm run dev.
FRONTEND_HOST="127.0.0.1"
FRONTEND_PORT="5173"

# UPSTOX_ACCESS_TOKEN: Your active Upstox Developer Access Token for server-side Python SDK calls.
# Obtain this from the Upstox Developer portal or set to 'SANDBOX_MOCK_TOKEN_NIFTY_SKILL' for simulated offline test mode.
UPSTOX_ACCESS_TOKEN=

# Optional sandbox token for paper trading and mock feed mode.
UPSTOX_SANDBOX_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJrZXlfaWQiOiJza192MS4wIiwiYWxnIjoiSFMyNTYifQ.eyJzdWIiOiI3NkFGMzUiLCJqdGkiOiI2YTMzODc2NmEwZTg2ODU4Y2ZkZmViNmQiLCJpc011bHRpQ2xpZW50IjpmYWxzZSwiaXNQbHVzUGxhbiI6ZmFsc2UsImlhdCI6MTc4MTc2MTg5NCwiaXNzIjoidWRhcGktZ2F0ZXdheS1zZXJ2aWNlIiwiZXhwIjoxNzgxODIwMDAwfQ.RpPPomdaoGuXQOZMMf6ZHIi0CHis1F4iUD-WNMd39og

# Redis connection string for caching layer.
REDIS_URL="redis://localhost:6379/0"

# DuckDB database path for OHLCV storage.
DUCKDB_PATH="upstox_market_data.duckdb"

# Cache TTL in seconds (default: 86400 = 24h).
CACHE_TTL_SECONDS=86400

# Cache-only mode: when true, serves only cached data without hitting Upstox API.
# Useful when API is rate-limited or for testing with historical data.
CACHE_ONLY_MODE=false
